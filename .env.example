# Copy to .env.local and fill in. Also set these in Vercel → Settings → Environment Variables.

# Clerk — publishable key is sent to the browser (must be VITE_ prefixed)
VITE_CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>

# Clerk — secret key, server-only (NEVER prefix with VITE_)
CLERK_SECRET_KEY=<your-clerk-secret-key>

# MongoDB Atlas connection string, server-only
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/masroof?retryWrites=true&w=majority
# Optional: explicit database name (otherwise taken from the URI / default)
# MONGODB_DB=masroof
